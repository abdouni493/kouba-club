VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
VITE_BREVO_API_KEY=your-brevo-api-key

# Server-side only (read by api/send-sms.ts) — no VITE_ prefix, never bundled to the client.
# Must also be set in the Vercel project's dashboard (Settings -> Environment Variables) for production.
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1XXXXXXXXXX
